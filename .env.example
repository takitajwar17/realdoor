# Baseline local app URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare deploy and remote tooling.
# Export these in your shell (or load them with direnv/dotenv tooling) before running remote deploy/Wrangler commands.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
DATABASE_ID=

# Optional integrations. Leave blank until you actually enable the feature.

# Google OAuth
# Callback URL: /sso/google/callback (for example, http://localhost:3000/sso/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend and email sender identity
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO=
SENTRY_DSN=

# AI services
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# At least 32 characters. Store as a Cloudflare secret in production.
READINESS_ENCRYPTION_KEY=

# Optional diagnostics
DB_SQL_LOG=
