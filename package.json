{
  "name": "@realdoor/agency",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "corpus:generate": "node scripts/generate-readiness-corpus.mjs",
    "prebuild": "pnpm run corpus:generate",
    "pretest": "pnpm run corpus:generate",
    "dev": "next dev -p 3000",
    "build": "next build --webpack",
    "build:prod": "pnpm run deploy:dry-run",
    "worker:build": "opennextjs-cloudflare build",
    "worker:deploy": "pnpm run worker:build && opennextjs-cloudflare deploy",
    "worker:preview": "pnpm run worker:build && opennextjs-cloudflare preview",
    "opennext:build": "pnpm run worker:build",
    "deploy:dry-run": "pnpm run worker:build && wrangler deploy --dry-run --outdir=dist",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "deploy": "pnpm run worker:deploy",
    "preview": "pnpm run worker:preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate:dev": "wrangler d1 migrations apply $(node scripts/get-db-name.mjs) --local",
    "d1:cache:clean": "wrangler d1 execute $(node scripts/get-db-name.mjs) --command \"DELETE FROM tags; DELETE FROM revalidations\" --remote",
    "email:dev": "email dev -d src/react-email -p 3003",
    "list:kv": "wrangler kv key list --namespace-id=$(node scripts/get-kv-id.mjs) --remote | jq '[.[].name]' > kv.log",
    "delete:kv": "wrangler kv bulk delete kv.log --namespace-id=$(node scripts/get-kv-id.mjs) --remote"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@marsidev/react-turnstile": "^1.4.2",
    "@opennextjs/cloudflare": "1.20.1",
    "@oslojs/encoding": "^1.1.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.7",
    "arctic": "^3.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "ipaddr.js": "^2.3.0",
    "lucide-react": "^0.563.0",
    "motion": "^11.18.0",
    "ms": "^2.1.3",
    "next": "16.2.10",
    "nextjs-toploader": "^3.8.16",
    "openai": "^6.21.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "remeda": "^2.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "ua-parser-js": "^2.0.9",
    "unpdf": "^1.4.0",
    "usehooks-ts": "^3.1.0",
    "zod": "^3.25.28",
    "zsa": "^0.6.0",
    "zsa-react": "^0.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/bundle-analyzer": "^16.1.6",
    "@react-email/preview-server": "5.2.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/ms": "^0.7.34",
    "@types/node": "^20.19.24",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.7",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.8.1",
    "react-email": "5.2.8",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.7",
    "wrangler": "^4.86.0"
  },
  "volta": {
    "node": "22.18.0"
  }
}
