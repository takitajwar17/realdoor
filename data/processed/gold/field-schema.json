{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RealDoor document extraction gold record",
  "type": "object",
  "required": [
    "document_id",
    "household_id",
    "document_type",
    "file_name",
    "fields"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "household_id": {
      "type": "string"
    },
    "document_type": {
      "type": "string"
    },
    "file_name": {
      "type": "string"
    },
    "synthetic": {
      "const": true
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "value",
          "page",
          "bbox",
          "bbox_units"
        ]
      }
    }
  }
}
